# ──────────────────────────────────────────────────────────────
# LegalTech Monitor — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA cometas el archivo .env al repositorio.
# ──────────────────────────────────────────────────────────────

# ── Anthropic API ─────────────────────────────────────────────
# Obtén tu clave en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Base de datos ─────────────────────────────────────────────
# SQLite (default para desarrollo):
DATABASE_URL=sqlite:///./judicial_monitor.db

# PostgreSQL (producción):
# DATABASE_URL=postgresql://user:password@localhost:5432/legaltech_db

# ── Directorio de boletines descargados ──────────────────────
BULLETIN_DIR=/tmp/bulletins

# ── Frontend ─────────────────────────────────────────────────
# URL del backend (usada por Next.js rewrites)
NEXT_PUBLIC_API_URL=http://localhost:8000
